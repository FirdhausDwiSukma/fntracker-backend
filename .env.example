# Database
DB_URL=postgres://user:password@localhost:5432/finance_tracker?sslmode=disable

# JWT
# WAJIB diganti dengan random string minimal 32 karakter sebelum deploy
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Server
PORT=8080
ENV=development
